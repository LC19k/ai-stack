###############################################################
# ai-stack — .env.example
# -------------------------------------------------------------
# This file defines ALL environment variables used by the stack.
# Copy to `.env` and fill in secrets where needed.
#
# Slot numbers are encoded in IP/MAC values only — not in names.
###############################################################

###############################################################
# BASE PATH (reference only, not used directly in compose)
###############################################################
AI_STACK_BASE_PATH=/mnt/user/appdata/ai-stack

###############################################################
# OPENWEBUI
###############################################################
AI_STACK_OPENWEBUI_IP=10.0.0.73
AI_STACK_OPENWEBUI_MAC=92:83:01:01:AA:73
AI_STACK_OPENWEBUI_PORT=3001
AI_STACK_OPENWEBUI_DATA_PATH=/mnt/user/appdata/ai-stack/openwebui
AI_STACK_CLASSIC_RAG_API_URL=http://classic-rag-api:8000

###############################################################
# LOCALAI (CPU-only, GGUF, on-demand loading)
###############################################################
AI_STACK_LOCALAI_PORT=8081
AI_STACK_LOCALAI_MODELS_PATH=/mnt/user/appdata/ai-stack/localai/models

# LocalAI API endpoint (internal)
AI_STACK_LOCALAI_URL=http://localai:8080/v1
AI_STACK_LOCALAI_API_KEY=none

# LocalAI runtime tuning
AI_STACK_LOCALAI_THREADS=4
AI_STACK_LOCALAI_CONTEXT_SIZE=4096
AI_STACK_LOCALAI_DEFAULT_MODEL=general_fast
AI_STACK_LOCALAI_LOAD_MODELS_ON_STARTUP=false

###############################################################
# FLOWISE
###############################################################
AI_STACK_FLOWISE_IP=10.0.0.75
AI_STACK_FLOWISE_MAC=92:83:01:01:AA:75
AI_STACK_FLOWISE_PORT=3002
AI_STACK_FLOWISE_DATA_PATH=/mnt/user/appdata/ai-stack/flowise
AI_STACK_FLOWISE_USERNAME=admin
AI_STACK_FLOWISE_PASSWORD=changeme

###############################################################
# N8N
###############################################################
AI_STACK_N8N_IP=10.0.0.76
AI_STACK_N8N_MAC=92:83:01:01:AA:76
AI_STACK_N8N_PORT=3003
AI_STACK_N8N_DATA_PATH=/mnt/user/appdata/ai-stack/n8n
AI_STACK_N8N_HOST=ai-stack-n8n

###############################################################
# LANGFUSE
###############################################################
AI_STACK_LANGFUSE_IP=10.0.0.77
AI_STACK_LANGFUSE_MAC=92:83:01:01:AA:77
AI_STACK_LANGFUSE_PORT=3004
AI_STACK_LANGFUSE_DATA_PATH=/mnt/user/appdata/ai-stack/langfuse
AI_STACK_LANGFUSE_URL=http://langfuse:3000
AI_STACK_LANGFUSE_DATABASE_URL=postgres://supabase_admin:YOUR_PASSWORD@supabase-postgres:5432/postgres
AI_STACK_LANGFUSE_PUBLIC_KEY=your_public_key
AI_STACK_LANGFUSE_SECRET_KEY=your_secret_key
AI_STACK_LANGFUSE_NEXTAUTH_SECRET=your_nextauth_secret

###############################################################
# QDRANT
###############################################################
AI_STACK_QDRANT_PORT=6333
AI_STACK_QDRANT_DATA_PATH=/mnt/user/appdata/ai-stack/qdrant
AI_STACK_QDRANT_URL=http://qdrant:6333

###############################################################
# NEO4J
###############################################################
AI_STACK_NEO4J_IP=10.0.0.78
AI_STACK_NEO4J_MAC=92:83:01:01:AA:78
AI_STACK_NEO4J_HTTP_PORT=7474
AI_STACK_NEO4J_BOLT_PORT=7687
AI_STACK_NEO4J_DATA_PATH=/mnt/user/appdata/ai-stack/neo4j/data
AI_STACK_NEO4J_LOGS_PATH=/mnt/user/appdata/ai-stack/neo4j/logs
AI_STACK_NEO4J_PASSWORD=changeme
AI_STACK_NEO4J_URI=bolt://neo4j:7687

###############################################################
# SUPABASE — POSTGRES
###############################################################
AI_STACK_SUPABASE_POSTGRES_DATA_PATH=/mnt/user/appdata/ai-stack/supabase/postgres
AI_STACK_SUPABASE_POSTGRES_PASSWORD=changeme

###############################################################
# SUPABASE — AUTH
###############################################################
AI_STACK_SUPABASE_AUTH_DATA_PATH=/mnt/user/appdata/ai-stack/supabase/auth
AI_STACK_SUPABASE_JWT_SECRET=changeme
AI_STACK_SUPABASE_SITE_URL=http://supabase-studio:3000

###############################################################
# SUPABASE — REST
###############################################################
# (No additional variables needed)

###############################################################
# SUPABASE — REALTIME
###############################################################
AI_STACK_SUPABASE_REALTIME_DATA_PATH=/mnt/user/appdata/ai-stack/supabase/realtime

###############################################################
# SUPABASE — STORAGE
###############################################################
AI_STACK_SUPABASE_STORAGE_DATA_PATH=/mnt/user/appdata/ai-stack/supabase/storage
AI_STACK_SUPABASE_ANON_KEY=your_anon_key
AI_STACK_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

###############################################################
# SUPABASE — STUDIO
###############################################################
AI_STACK_SUPABASE_STUDIO_DATA_PATH=/mnt/user/appdata/ai-stack/supabase/studio
AI_STACK_SUPABASE_STUDIO_IP=10.0.0.80
AI_STACK_SUPABASE_STUDIO_MAC=92:83:01:01:AA:80
AI_STACK_SUPABASE_STUDIO_PORT=3005

###############################################################
# CLASSIC RAG API
###############################################################
AI_STACK_CLASSIC_RAG_API_PORT=8000
AI_STACK_CLASSIC_RAG_DATA_PATH=/mnt/user/appdata/ai-stack/classic-rag

###############################################################
# GRAPHRAG API
###############################################################
AI_STACK_GRAPHRAG_API_PORT=8001
AI_STACK_GRAPHRAG_DATA_PATH=/mnt/user/appdata/ai-stack/graphra
